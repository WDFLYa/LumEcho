<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="nuc.edu.lumecho.mapper.PhotographyActivityMapper">

    <!-- 管理员：查询待开始活动 -->
    <select id="selectPendingActivity"
            resultType="nuc.edu.lumecho.model.entity.PhotographyActivity">
        SELECT *
        FROM photography_activity
        WHERE status = 0
        ORDER BY create_time DESC
    </select>

</mapper>